# =============================================
# PertoDeMim — Variáveis de Ambiente (Portainer)
# Cole este conteúdo na aba "Environment" da stack
# =============================================

# --- Backend ---
NODE_ENV=production
PORT=4000

# MongoDB (sua connection string)
MONGODB_URI=mongodb+srv://viniciusgnandt:0c4n8MDAI9UHwXdQ@clusterclaude.xhuqf2s.mongodb.net/pertoDeMim?appName=ClusterClaude

# JWT — troque por valores longos e aleatórios em produção
JWT_SECRET=TROQUE_POR_UM_SEGREDO_LONGO_AQUI
JWT_REFRESH_SECRET=TROQUE_POR_OUTRO_SEGREDO_LONGO_AQUI
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — URL pública do seu frontend
FRONTEND_URL=https://pertodemim.viniciusgnandt.com.br

# --- Google OAuth (opcional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://pertodemim.viniciusgnandt.com.br:4000/api/auth/google/callback

# --- Apple OAuth (opcional) ---
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_LOCATION=./apple-private-key.p8
APPLE_CALLBACK_URL=https://pertodemim.viniciusgnandt.com.br:4000/api/auth/apple/callback

# --- Stripe (opcional — sem isso o boost ativa em modo dev) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=https://pertodemim.viniciusgnandt.com.br/dashboard?boost=success
STRIPE_CANCEL_URL=https://pertodemim.viniciusgnandt.com.br/dashboard?boost=cancelled

# --- OCI Object Storage (opcional — sem isso usa upload local) ---
OCI_NAMESPACE=
OCI_BUCKET_NAME=pertodemim-images
OCI_REGION=sa-saopaulo-1
OCI_ACCESS_KEY_ID=
OCI_SECRET_ACCESS_KEY=
