PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/pertodemim?replicaSet=rs0

# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_REFRESH_SECRET=change_this_to_another_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Apple OAuth
APPLE_CLIENT_ID=your_apple_client_id
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_PRIVATE_KEY_LOCATION=./apple-private-key.p8
APPLE_CALLBACK_URL=http://localhost:3001/api/auth/apple/callback

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_SUCCESS_URL=http://localhost:5173/dashboard?boost=success
STRIPE_CANCEL_URL=http://localhost:5173/dashboard?boost=cancelled

# OCI Object Storage
OCI_NAMESPACE=your_oci_namespace
OCI_BUCKET_NAME=pertodemim-images
OCI_REGION=sa-saopaulo-1
OCI_ACCESS_KEY_ID=your_oci_access_key
OCI_SECRET_ACCESS_KEY=your_oci_secret_key
